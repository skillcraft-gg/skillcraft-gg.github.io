{
  "name": "skillcraft-pages",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Skillcraft static site built with Next.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "next lint",
    "check:skills": "node ./scripts/check-skills-pages.mjs",
    "check:credentials": "node ./scripts/check-credentials-pages.mjs",
    "prepare": "sh ./scripts/install-git-hooks.sh",
    "commitlint": "commitlint --from HEAD~1 --to HEAD"
  },
  "dependencies": {
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "typescript": "5.9.3"
  }
}
